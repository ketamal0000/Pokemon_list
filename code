/* ── CARD MODAL ── */
function openAdd() {
  editId=null;
  document.getElementById('modalTitle').textContent='カードを追加';
  ['fName','fSet','fNumber','fBuy','fMarket','fNotes'].forEach(id=>document.getElementById(id).value='');
  document.getElementById('fGrade').value='10'; document.getElementById('fQty').value='1';
  document.getElementById('ebayHint').style.display='none';
  document.getElementById('modalActions').innerHTML=`<button class="btn-primary" onclick="saveCard()">追加する</button>`;
  document.getElementById('modal').style.display='flex';
  document.getElementById('fName').oninput=updateEbayHint;
}
function openEdit(id) {
  const c=cards.find(x=>x.id===id); if(!c) return;
  editId=id;
  document.getElementById('modalTitle').textContent='カードを編集';
  document.getElementById('fName').value=c.name; document.getElementById('fSet').value=c.set||'';
  document.getElementById('fNumber').value=c.number||''; document.getElementById('fGrade').value=c.grade;
  document.getElementById('fQty').value=c.qty||1; document.getElementById('fBuy').value=c.buy||'';
  document.getElementById('fMarket').value=c.market||''; document.getElementById('fNotes').value=c.notes||'';
  const h=document.getElementById('ebayHint');
  h.style.display='block'; h.href=ebayUrl(c.name); h.textContent='🔍 eBayで「'+c.name+'」を確認 →';
  document.getElementById('modalActions').innerHTML=`
    <button class="btn-primary" onclick="saveCard()">更新する</button>
    <button class="btn-secondary" onclick="closeModal();setTimeout(()=>openHistModal(${id}),200)">📊 価格履歴を記録する</button>
    <button class="btn-danger" onclick="deleteCard()">削除する</button>`;
  document.getElementById('modal').style.display='flex';
  document.getElementById('fName').oninput=updateEbayHint;
}
function updateEbayHint() {
  const n=document.getElementById('fName').value.trim(), h=document.getElementById('ebayHint');
  if(n){h.style.display='block';h.href=ebayUrl(n);h.textContent='🔍 eBayで「PSA 10 '+n+'」を確認 →';}
  else h.style.display='none';
}
function closeModal() { document.getElementById('modal').style.display='none'; }
function handleOverlay(e) { if(e.target===e.currentTarget) closeModal(); }
function saveCard() {
  const name=document.getElementById('fName').value.trim();
  const market=parseFloat(document.getElementById('fMarket').value);
  if(!name){alert('カード名を入力してください');return;}
  if(isNaN(market)){alert('時価を入力してください');return;}
  const existing=editId?cards.find(c=>c.id===editId):null;
  const card={
    id:editId||Date.now(), name, set:document.getElementById('fSet').value.trim(),
    number:document.getElementById('fNumber').value.trim(), grade:parseInt(document.getElementById('fGrade').value),
    qty:parseInt(document.getElementById('fQty').value)||1, buy:parseFloat(document.getElementById('fBuy').value)||0,
    market, notes:document.getElementById('fNotes').value.trim(),
    history:existing?[...(existing.history||[])]:[]
  };
  // Auto-record price if changed
  if(!existing||existing.market!==market) {
    const td=today(), already=card.history.find(h=>h.date===td);
    if(already) already.price=market; else card.history.push({date:td,price:market});
    card.history.sort((a,b)=>a.date.localeCompare(b.date));
  }
  cards=editId?cards.map(c=>c.id===editId?card:c):[...cards,card];
  save(); closeModal(); render();
}
function deleteCard() {
  if(!confirm('このカードを削除しますか？')) return;
  cards=cards.filter(c=>c.id!==editId); save(); closeModal(); render();
}

/* ── HISTORY MODAL ── */
function openHistModal(id) {
  histCardId=id;
  const c=cards.find(x=>x.id===id); if(!c) return;
  document.getElementById('histModalTitle').textContent=c.name;
  document.getElementById('hPrice').value=c.market||'';
  document.getElementById('hDate').value=today();
  renderHistList(c);
  document.getElementById('histModal').style.display='flex';
}
function renderHistList(c) {
  const hist=[...(c.history||[])].sort((a,b)=>b.date.localeCompare(a.date));
  let html='';
  hist.forEach((h,i)=>{
    const prev=hist[i+1], chg=prev?((h.price-prev.price)/prev.price*100).toFixed(1):null;
    html+=`<div class="hm-row">
      <div><div class="hm-date">${disp(h.date)}</div>${chg!==null?`<div class="hm-change ${parseFloat(chg)>=0?'green':'red'}">${parseFloat(chg)>=0?'▲':'▼'}${Math.abs(chg)}%</div>`:'<div class="hm-change" style="color:#444">初回記録</div>'}</div>
      <div style="display:flex;align-items:center;gap:6px"><div class="hm-price">${usd(h.price)}</div><button class="hm-del" onclick="delHist('${h.date}')">🗑</button></div>
    </div>`;
  });
  document.getElementById('histList').innerHTML=html||'<div style="color:#444;font-size:13px;padding:16px 0;text-align:center">記録がありません<br>上のフォームから追加できます</div>';
}
function addHistoryEntry() {
  const price=parseFloat(document.getElementById('hPrice').value), date=document.getElementById('hDate').value;
  if(isNaN(price)||!date){alert('価格と日付を入力してください');return;}
  const c=cards.find(x=>x.id===histCardId); if(!c) return;
  if(!c.history) c.history=[];
  const ex=c.history.find(h=>h.date===date);
  if(ex) ex.price=price; else c.history.push({date,price});
  c.history.sort((a,b)=>a.date.localeCompare(b.date));
  if(date===today()) c.market=price;
  save(); renderHistList(c); render();
}
function delHist(date) {
  if(!confirm('この記録を削除しますか？')) return;
  const c=cards.find(x=>x.id===histCardId); if(!c) return;
  c.history=(c.history||[]).filter(h=>h.date!==date);
  save(); renderHistList(c); render();
}
function closeHistModal() { document.getElementById('histModal').style.display='none'; }
function handleHistOverlay(e) { if(e.target===e.currentTarget) closeHistModal(); }

