function initPortfolioCanvas(ph) {
  const wrap=document.getElementById('phWrap'); if(!wrap) return;
  const canvas=document.getElementById('phCanvas'); if(!canvas) return;
  const W=wrap.clientWidth, H=110;
  const dpr=window.devicePixelRatio||1;
  canvas.width=W*dpr; canvas.height=H*dpr;
  canvas.style.width=W+'px'; canvas.style.height=H+'px';
  _phCanvas=canvas; _phCtx=canvas.getContext('2d'); _phCtx.scale(dpr,dpr);
  drawPhChart(ph, ph.length-1, W, H);
}

function drawPhChart(ph, activeIdx, W, H) {
  const ctx=_phCtx; if(!ctx) return;
  ctx.clearRect(0,0,W,H);
  const prices=ph.map(p=>p.total);
  const mn=Math.min(...prices), mx=Math.max(...prices), rng=mx-mn||1, pad=8;
  const up=prices[prices.length-1]>=prices[0];
  const col=up?'#4ade80':'#f87171';
  const x=(i)=>pad+(i/(ph.length-1))*(W-pad*2);
  const y=(v)=>H-pad-((v-mn)/rng)*(H-pad*2);

  // gradient fill
  const grad=ctx.createLinearGradient(0,0,0,H);
  grad.addColorStop(0,up?'rgba(74,222,128,.2)':'rgba(248,113,113,.2)');
  grad.addColorStop(1,'rgba(0,0,0,0)');
  ctx.beginPath();
  ph.forEach((p,i)=>{ i===0?ctx.moveTo(x(i),y(p.total)):ctx.lineTo(x(i),y(p.total)); });
  ctx.lineTo(x(ph.length-1),H-pad); ctx.lineTo(x(0),H-pad); ctx.closePath();
  ctx.fillStyle=grad; ctx.fill();

  // line
  ctx.beginPath();
  ph.forEach((p,i)=>{ i===0?ctx.moveTo(x(i),y(p.total)):ctx.lineTo(x(i),y(p.total)); });
  ctx.strokeStyle=col; ctx.lineWidth=2.5; ctx.lineJoin='round'; ctx.stroke();

  // scrubber
  const sx=x(activeIdx), sy=y(ph[activeIdx].total);
  ctx.beginPath(); ctx.setLineDash([3,4]);
  ctx.strokeStyle='rgba(255,255,255,.25)'; ctx.lineWidth=1;
  ctx.moveTo(sx,pad); ctx.lineTo(sx,H-pad); ctx.stroke(); ctx.setLineDash([]);
  ctx.beginPath(); ctx.arc(sx,sy,6,0,Math.PI*2); ctx.fillStyle=col; ctx.fill();
  ctx.beginPath(); ctx.arc(sx,sy,3,0,Math.PI*2); ctx.fillStyle='#fff'; ctx.fill();
}

function onSlider(val) {
  const idx=parseInt(val);
  if(!_phData||!_phData.length) return;
  const entry=_phData[idx], first=_phData[0];
  document.getElementById('phBig').textContent=usd(entry.total);
  document.getElementById('phDate').textContent=disp(entry.date);
  const chgAmt=entry.total-first.total;
  const chgP=first.total>0?(chgAmt/first.total*100).toFixed(1):0;
  const el=document.getElementById('phChange');
  if(idx===0){el.textContent=''; }
  else {
    el.textContent=(chgAmt>=0?'▲ ':'▼ ')+usd(Math.abs(chgAmt))+'（'+(chgAmt>=0?'+':'')+chgP+'%）';
    el.className='ph-change '+(chgAmt>=0?'green':'red');
  }
  const W=_phCanvas?parseInt(_phCanvas.style.width):300;
  drawPhChart(_phData, idx, W, 110);
}

/* ── CHART TAB ── */
function renderChart() {
  const tM=cards.reduce((s,c)=>s+(c.market||0)*(c.qty||1),0);
  const sorted=[...cards].sort((a,b)=>(b.market*b.qty)-(a.market*a.qty));
  const pnlS=[...cards].sort((a,b)=>((b.market-b.buy)*b.qty)-((a.market-a.buy)*a.qty));
  const bars=sorted.map((c,i)=>{
    const val=(c.market||0)*(c.qty||1), p=tM>0?(val/tM*100):0, col=COLORS[i%COLORS.length];
    return `<div class="bar-row"><div class="bar-label-row"><div class="bar-name">${esc(c.name)}</div><div class="bar-pct" style="color:${col}">${p.toFixed(1)}%</div></div>
      <div class="bar-track"><div class="bar-fill" style="width:${p}%;background:${col}"></div></div>
      <div class="bar-sub">${usd(val)}</div></div>`;
  }).join('');
  const ranks=pnlS.map(c=>{
    const pnlA=((c.market||0)-(c.buy||0))*(c.qty||1), pnlP=c.buy>0?((c.market-c.buy)/c.buy*100).toFixed(1):null;
    return `<div class="rank-row"><div class="rank-left"><div class="rank-name">${esc(c.name)}</div>${gradeBadge(c.grade)}</div>
      <div class="rank-right"><div class="rank-pnl ${pnlA>=0?'green':'red'}">${pnlA>=0?'+':''}${usd(pnlA)}</div>
      <div class="rank-pct">${pnlP!==null?(pnlA>=0?'+':'')+pnlP+'%':'—'}</div></div></div>`;
  }).join('');
  document.getElementById('content').innerHTML=`
    <div class="analysis-card"><div class="analysis-title">時価構成比</div>${bars||'<div style="color:#444;font-size:13px">カードがありません</div>'}</div>
    <div class="analysis-card"><div class="analysis-title">損益ランキング</div>${ranks||'<div style="color:#444;font-size:13px">カードがありません</div>'}</div>`;
}

/* ── TABS ── */
function switchTab(t) {
  currentTab=t;
  ['list','history','chart'].forEach(id=>{
    const el=document.getElementById('tab'+id.charAt(0).toUpperCase()+id.slice(1));
    if(el) el.className='tab'+(t===id?' active':'');
