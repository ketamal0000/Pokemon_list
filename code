  if(!localStorage.getItem('install-hint-dismissed')&&!window.navigator.standalone)
    document.getElementById('installBanner').style.display='flex';
}
function dismissInstall() { localStorage.setItem('install-hint-dismissed','1'); document.getElementById('installBanner').style.display='none'; }

