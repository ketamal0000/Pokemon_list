      <div style="display:flex;justify-content:space-between">
        <div style="font-size:10px;color:#444">${disp(hist[0].date)}<br><span style="color:#888">${usd(prices[0])}</span></div>
        <div style="font-size:10px;color:#444;text-align:right">${disp(hist[hist.length-1].date)}<br><span style="color:#888">${usd(prices[prices.length-1])}</span></div>
      </div>
    </div>`;
  });
  if(!cardSections) cardSections=`<div style="text-align:center;color:#444;padding:20px;font-size:13px">各カードの「📊 履歴」から記録を追加してください</div>`;

