/* ── HISTORY TAB ── */
// Aggregate all card histories into a portfolio total timeline
function buildTimeline() {
  const dateMap={};
  cards.forEach(c=>{
    (c.history||[]).forEach(h=>{
      if(!dateMap[h.date]) dateMap[h.date]={};
      dateMap[h.date][c.id]=h.price*(c.qty||1);
    });
  });
  // For each date, fill in missing cards with their closest earlier price
  const allDates=Object.keys(dateMap).sort();
  if(!allDates.length) return [];
  // Forward-fill per card
  const filled={};
  allDates.forEach(date=>{
    cards.forEach(c=>{
      if(dateMap[date][c.id]!==undefined) {
        filled[c.id]=dateMap[date][c.id];
      }
      if(filled[c.id]!==undefined) {
        dateMap[date][c.id]=filled[c.id];
      }
    });
  });
  return allDates.map(date=>({
    date, total:Object.values(dateMap[date]).reduce((s,v)=>s+v,0)
  }));
}

let _phData=[], _phCanvas=null, _phCtx=null;

