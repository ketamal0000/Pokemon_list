        </div>
        <div style="text-align:right;flex-shrink:0">
          <div style="font-family:'Playfair Display',serif;font-size:17px;color:var(--gold)">${usd(prices[prices.length-1])}</div>
          <div class="${up?'green':'red'}" style="font-size:12px;font-weight:600">${up?'▲':'▼'}${Math.abs(chg)}%</div>
        </div>
      </div>
